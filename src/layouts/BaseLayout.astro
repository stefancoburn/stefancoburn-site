---
import '@fontsource/newsreader/400.css';
import '@fontsource/newsreader/500.css';
import '@fontsource/newsreader/600.css';
import '@fontsource/newsreader/400-italic.css';
import '@fontsource/lato/400.css';
import '@fontsource/lato/700.css';
import '@fontsource/lato/900.css';
import '../styles/global.css';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  active?: 'home' | 'bookshelf' | 'book-notes' | 'essays' | 'quotes' | 'now' | 'about';
}

const {
  title,
  description = "Stefan Coburn — engineer, firefighter, pragmatic optimist.",
  ogImage,
  active = 'home',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://stefancoburn.com');
const ogImageURL = ogImage
  ? new URL(ogImage, 'https://stefancoburn.com').href
  : 'https://stefancoburn.com/og/home.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="alternate" type="application/rss+xml" title="Stefan Coburn" href="/rss.xml" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Stefan Coburn" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
</head>
<body>
  <header class="site-header">
    <a href="/" class="brand">
      <span class="brand-mark">sc</span>
      <span class="brand-word">Stefan Coburn</span>
    </a>
    <nav class="site-nav">
      <a href="/"            class={active === 'home'       ? 'active' : ''}>Home</a>
      <a href="/bookshelf"   class={active === 'bookshelf'  ? 'active' : ''}>Bookshelf</a>
      <a href="/book-notes"  class={active === 'book-notes' ? 'active' : ''}>Book Notes</a>
      <a href="/essays"      class={active === 'essays'     ? 'active' : ''}>Essays</a>
      <a href="/quotes"      class={active === 'quotes'     ? 'active' : ''}>Quotes</a>
      <a href="/now"         class={active === 'now'        ? 'active' : ''}>Now</a>
      <a href="/about"       class={active === 'about'      ? 'active' : ''}>About</a>
    </nav>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="footer-l">
      <div class="footer-socials">
        <a href="https://x.com/stefancoburn" target="_blank" rel="noopener">X</a>
        <a href="https://linkedin.com/in/stefancoburn" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://t.me/stefancoburn" target="_blank" rel="noopener">Telegram</a>
        <a href="/rss.xml">RSS</a>
      </div>
      <div class="footer-mono">© {new Date().getFullYear()} Stefan Coburn · built with Astro · deployed on Vercel</div>
    </div>
    <div class="footer-mono" style="text-align:right">Designed for clarity<br>and calm.</div>
  </footer>

  <SpeedInsights />
  <Analytics />
</body>
</html>
