---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import books from '../data/books.json';

const bookNotes = await getCollection('book-notes');
const noteIds = new Set(bookNotes.map(n => n.id));

const booksWithLinks = books.map(b => ({
  ...b,
  noteLink: noteIds.has(b.slug) ? `/book-notes/${b.slug}` : null,
}));

const allGenres = [...new Set(books.flatMap(b => b.genres))].sort();

const byTier = {
  fire:    booksWithLinks.filter(b => b.rating === 5),
  keepers: booksWithLinks.filter(b => b.rating !== null && b.rating >= 4 && b.rating < 5).sort((a,b) => b.rating - a.rating || a.title.localeCompare(b.title)),
  worth:   booksWithLinks.filter(b => b.rating !== null && b.rating >= 3 && b.rating < 4).sort((a,b) => b.rating - a.rating || a.title.localeCompare(b.title)),
  once:    booksWithLinks.filter(b => b.rating !== null && b.rating > 0 && b.rating < 3).sort((a,b) => b.rating - a.rating || a.title.localeCompare(b.title)),
  unrated: booksWithLinks.filter(b => b.rating === null),
};

function stars(r: number | null): string {
  if (r == null) return '';
  const full = Math.floor(r);
  const frac = r - full;
  let extra = '';
  if (frac >= 0.25 && frac < 0.75) extra = '½';
  else if (frac >= 0.75) extra = '★';
  return '★'.repeat(full) + extra;
}
---
<BaseLayout title="Bookshelf — Stefan Coburn" description="Every book I've read — rated, tagged, and tiered." ogImage="/og/book-notes.png" active="bookshelf">
  <main class="container-wide">
    <div class="page-title">
      <div>
        <div class="eyebrow">The library</div>
        <h1>Bookshelf<em>.</em></h1>
      </div>
    </div>
    <p class="page-intro">Every book I've read — <em>{books.length} titles,</em> grouped by how much they shaped me. Where I've written something, you'll see a <span class="badge-inline">Notes</span> kicker on the cover.</p>

    <div class="shelf-controls" id="controls">
      <div class="control-row">
        <span class="control-label">Filter</span>
        <button class="pill active" data-genre="all">All · {books.length}</button>
        {allGenres.map(g => {
          const n = books.filter(b => b.genres.includes(g)).length;
          return <button class="pill" data-genre={g}>{g} · {n}</button>;
        })}
      </div>
      <div class="control-row">
        <span class="control-label">Sort</span>
        <button class="pill active" data-sort="tier">By tier</button>
        <button class="pill" data-sort="rating-desc">Rating ↓</button>
        <button class="pill" data-sort="rating-asc">Rating ↑</button>
        <button class="pill" data-sort="title-asc">Title A–Z</button>
      </div>
    </div>

    {/* Shelf of Fire — cover grid */}
    <section class="tier-section" data-tier="fire">
      <div class="tier-head">
        <div class="tier-stars">★★★★★</div>
        <div class="tier-name">Shelf of Fire<small>books that rewired how I think</small></div>
        <div class="tier-count">{byTier.fire.length} books</div>
      </div>
      <div class="book-grid">
        {byTier.fire.map(b => (
          <a class="book" href={b.noteLink || '#'} id={b.slug} data-genres={JSON.stringify(b.genres)} data-rating={b.rating} data-title={b.title}>
            <div class="book-cover">
              {b.hasCover
                ? <img src={`/images/covers/${b.slug}.jpg`} alt={b.title} loading="lazy" decoding="async" width="120" height="180" />
                : <div class="placeholder-cover"><div class="pt">{b.title}</div><div class="pa">{b.author}</div></div>
              }
              {b.noteLink && <span class="notes-kicker">Notes</span>}
            </div>
            <div class="book-info">
              <div class="t">{b.title}</div>
              <div class="a">{b.author}</div>
              <div class="r">{stars(b.rating)} <span class="n">{b.rating!.toFixed(1)}</span></div>
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* Keepers / Worth / Once — cover grid also */}
    {[
      { key: 'keepers', stars: '★★★★½', name: 'Keepers', sub: "I'd re-read, I'd recommend", list: byTier.keepers },
      { key: 'worth',   stars: '★★★★',  name: 'Worth the time', sub: 'solid — one good idea or more', list: byTier.worth },
      { key: 'once',    stars: '★★★',   name: 'Read once', sub: "there's always a lesson", list: byTier.once },
    ].map(t => (
      <section class="tier-section" data-tier={t.key}>
        <div class="tier-head">
          <div class="tier-stars">{t.stars}</div>
          <div class="tier-name">{t.name}<small>{t.sub}</small></div>
          <div class="tier-count">{t.list.length} books</div>
        </div>
        <div class="book-grid">
          {t.list.map(b => (
            <a class="book" href={b.noteLink || '#'} id={b.slug} data-genres={JSON.stringify(b.genres)} data-rating={b.rating} data-title={b.title}>
              <div class="book-cover">
                {b.hasCover
                  ? <img src={`/images/covers/${b.slug}.jpg`} alt={b.title} loading="lazy" decoding="async" width="120" height="180" />
                  : <div class="placeholder-cover"><div class="pt">{b.title}</div><div class="pa">{b.author}</div></div>
                }
                {b.noteLink && <span class="notes-kicker">Notes</span>}
              </div>
              <div class="book-info">
                <div class="t">{b.title}</div>
                <div class="a">{b.author}</div>
                <div class="r">{stars(b.rating)} <span class="n">{b.rating!.toFixed(1)}</span></div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    {byTier.unrated.length > 0 && (
      <section class="tier-section" data-tier="unrated">
        <div class="tier-head">
          <div class="tier-stars">—</div>
          <div class="tier-name">Still chewing<small>ratings forthcoming</small></div>
          <div class="tier-count">{byTier.unrated.length} books</div>
        </div>
        <div class="book-grid">
          {byTier.unrated.map(b => (
            <a class="book" href={b.noteLink || '#'} id={b.slug} data-genres={JSON.stringify(b.genres)} data-rating="0" data-title={b.title}>
              <div class="book-cover">
                {b.hasCover
                  ? <img src={`/images/covers/${b.slug}.jpg`} alt={b.title} loading="lazy" decoding="async" width="120" height="180" />
                  : <div class="placeholder-cover"><div class="pt">{b.title}</div><div class="pa">{b.author}</div></div>
                }
              </div>
              <div class="book-info">
                <div class="t">{b.title}</div>
                <div class="a">{b.author}</div>
                <div class="r" style="color:var(--faint)">unrated</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <script>
    const genreBtns = document.querySelectorAll<HTMLButtonElement>('.pill[data-genre]');
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-title]'));
    const tiers = Array.from(document.querySelectorAll<HTMLElement>('.tier-section'));
    genreBtns.forEach(btn => btn.addEventListener('click', () => {
      genreBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const g = btn.dataset.genre!;
      items.forEach(el => {
        const genres = JSON.parse(el.dataset.genres!) as string[];
        (el as HTMLElement).style.display = (g === 'all' || genres.includes(g)) ? '' : 'none';
      });
      tiers.forEach(t => {
        const visible = Array.from(t.querySelectorAll<HTMLElement>('[data-title]')).filter(el => el.style.display !== 'none').length;
        (t as HTMLElement).style.display = visible ? '' : 'none';
      });
    }));
  </script>
</BaseLayout>
