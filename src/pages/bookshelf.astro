---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import books from '../data/books.json';

// Get book notes to link to
const bookNotes = await getCollection('book-notes');
const noteIds = new Set(bookNotes.map(n => n.id));

// Extract all unique genres
const allGenres = [...new Set(books.flatMap(b => b.genres))].sort();

// Prepare books with note links
const booksWithLinks = books.map(b => ({
  ...b,
  noteLink: noteIds.has(b.slug) ? `/book-notes/${b.slug}` : null,
}));
---

<BaseLayout title="Bookshelf - Stefan Coburn" description="Every book I've read — rated, tagged, and sortable." ogImage="/og/book-notes.png">
  <div class="bookshelf-header">
    <h1>Bookshelf</h1>
    <p class="bookshelf-subtitle">{books.length} books — filtered by genre, sorted by rating</p>
  </div>

  <div class="bookshelf-controls" id="controls">
    <div class="filter-row">
      <button class="filter-btn active" data-genre="all">All</button>
      {allGenres.map(genre => (
        <button class="filter-btn" data-genre={genre}>{genre}</button>
      ))}
    </div>
    <div class="sort-row">
      <label>Sort by:</label>
      <button class="sort-btn active" data-sort="rating-desc">Highest Rated</button>
      <button class="sort-btn" data-sort="rating-asc">Lowest Rated</button>
      <button class="sort-btn" data-sort="title-asc">Title A–Z</button>
    </div>
  </div>

  <div class="book-count" id="book-count">{books.length} books</div>

  <div class="book-grid" id="book-grid">
    {booksWithLinks
      .sort((a, b) => b.rating - a.rating)
      .map(book => (
        <div
          class="book-card"
          data-genres={JSON.stringify(book.genres)}
          data-rating={book.rating}
          data-title={book.title}
        >
          {book.noteLink ? (
            <a href={book.noteLink} class="book-cover-link">
              {book.hasCover ? (
                <img
                  src={`/images/covers/${book.slug}.jpg`}
                  alt={book.title}
                  class="book-cover"
                  loading="lazy"
                  width="140"
                  height="210"
                />
              ) : (
                <div class="book-cover-placeholder">
                  <span class="placeholder-title">{book.title}</span>
                  <span class="placeholder-author">{book.author}</span>
                </div>
              )}
              <span class="has-notes-badge">Notes</span>
            </a>
          ) : (
            <div class="book-cover-wrapper">
              {book.hasCover ? (
                <img
                  src={`/images/covers/${book.slug}.jpg`}
                  alt={book.title}
                  class="book-cover"
                  loading="lazy"
                  width="140"
                  height="210"
                />
              ) : (
                <div class="book-cover-placeholder">
                  <span class="placeholder-title">{book.title}</span>
                  <span class="placeholder-author">{book.author}</span>
                </div>
              )}
            </div>
          )}
          <div class="book-info">
            <span class="book-title">{book.title}</span>
            <span class="book-author">{book.author}</span>
            <span class="book-rating">
              {'★'.repeat(Math.floor(book.rating))}
              {book.rating % 1 >= 0.25 && book.rating % 1 < 0.75 ? '½' : book.rating % 1 >= 0.75 ? '★' : ''}
              <span class="rating-number">{book.rating}</span>
            </span>
          </div>
        </div>
      ))
    }
  </div>

  <script>
    const grid = document.getElementById('book-grid');
    const cards = Array.from(grid.querySelectorAll('.book-card'));
    const countEl = document.getElementById('book-count');
    let activeGenre = 'all';
    let activeSort = 'rating-desc';

    // Filter buttons
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeGenre = btn.dataset.genre;
        applyFilterAndSort();
      });
    });

    // Sort buttons
    document.querySelectorAll('.sort-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeSort = btn.dataset.sort;
        applyFilterAndSort();
      });
    });

    function applyFilterAndSort() {
      // Filter
      let visible = cards.filter(card => {
        if (activeGenre === 'all') return true;
        const genres = JSON.parse(card.dataset.genres);
        return genres.includes(activeGenre);
      });

      // Sort
      visible.sort((a, b) => {
        switch (activeSort) {
          case 'rating-desc':
            return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
          case 'rating-asc':
            return parseFloat(a.dataset.rating) - parseFloat(b.dataset.rating);
          case 'title-asc':
            return a.dataset.title.localeCompare(b.dataset.title);
          default:
            return 0;
        }
      });

      // Hide all, then show and reorder visible
      cards.forEach(c => { c.style.display = 'none'; });
      visible.forEach(c => {
        c.style.display = '';
        grid.appendChild(c);
      });

      countEl.textContent = `${visible.length} book${visible.length !== 1 ? 's' : ''}`;
    }
  </script>
</BaseLayout>

<style>
  .bookshelf-header {
    margin-bottom: 1.5rem;
  }

  .bookshelf-header h1 {
    margin-bottom: 0.25rem;
  }

  .bookshelf-subtitle {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.9rem;
  }

  .bookshelf-controls {
    margin-bottom: 1.5rem;
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }

  .filter-btn,
  .sort-btn {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn:hover,
  .sort-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn.active,
  .sort-btn.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .sort-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .sort-row label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .book-count {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1.5rem;
  }

  .book-card {
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease;
  }

  .book-card:hover {
    transform: translateY(-4px);
  }

  .book-cover-link,
  .book-cover-wrapper {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    transition: box-shadow 0.2s ease;
  }

  .book-cover-link:hover,
  .book-card:hover .book-cover-wrapper {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .book-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #d4764e 0%, #b85a3a 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0.75rem;
    text-align: center;
  }

  .placeholder-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.7rem;
    color: white;
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }

  .placeholder-author {
    font-size: 0.55rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.2;
  }

  .has-notes-badge {
    position: absolute;
    top: 6px;
    right: 6px;
    background: var(--color-accent);
    color: white;
    font-family: var(--font-heading);
    font-size: 0.55rem;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .book-info {
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .book-title {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
  }

  .book-author {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .book-rating {
    font-size: 0.65rem;
    color: var(--color-accent);
    margin-top: 0.15rem;
  }

  .rating-number {
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    margin-left: 0.2rem;
    font-size: 0.6rem;
  }

  @media (max-width: 600px) {
    .book-grid {
      grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
      gap: 1rem;
    }

    .filter-row {
      gap: 0.3rem;
    }

    .filter-btn,
    .sort-btn {
      font-size: 0.65rem;
      padding: 0.25rem 0.5rem;
    }
  }
</style>
