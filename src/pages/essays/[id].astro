---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { id: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
const dateStr = new Date(essay.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const body = essay.body || '';
const words = body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(words / 250));
---

<BaseLayout title={`${essay.data.title} - Stefan Coburn`} description={essay.data.description}>
  <article>
    <div class="article-header">
      <h1>{essay.data.title}</h1>
      <p class="article-meta">{dateStr} &middot; {readingTime} min read</p>
    </div>
    <div class="article-content">
      <Content />
    </div>
  </article>
  <p style="margin-top: 3rem;">
    <a href="/essays">&larr; All Essays</a>
  </p>
</BaseLayout>
