---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Essays - Stefan Coburn" ogImage="/og/essays.png">
  <h1>Essays</h1>
  <p style="color: var(--color-text-muted); margin-bottom: 2rem;">Thoughts on technology, society, and the good life.</p>

  {essays.length > 0 ? (
    <ul class="post-list">
      {essays.map((essay) => (
        <li>
          <a href={`/essays/${essay.id}`}>{essay.data.title}</a>
          {essay.data.description && <span class="post-description">{essay.data.description}</span>}
          <span class="post-date">{new Date(essay.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--color-text-muted); font-style: italic;">Coming soon.</p>
  )}
</BaseLayout>
