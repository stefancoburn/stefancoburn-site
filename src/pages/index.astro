---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import books from '../data/books.json';

const bookNotes = (await getCollection('book-notes')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const essays = (await getCollection('essays')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const totalBooks = books.length;
const totalNotes = bookNotes.length;

// Pick up to 3 books to show as "currently reading" — tweak by editing the slugs below.
const currentlyReadingSlugs = [
  'the-true-believer',
  '1929',
  'kill-chain',
];
const currentlyReading = currentlyReadingSlugs
  .map(slug => books.find(b => b.slug === slug))
  .filter(Boolean);
---
<BaseLayout title="Stefan Coburn" ogImage="/og/home.png" active="home">
  <main class="container-wide">
    <div class="hero-editorial">
      <div>
        <div class="eyebrow">Indiana · est. 1988</div>
        <h1 class="hero-name">Stefan<br><em>Coburn.</em></h1>
        <p class="hero-sub"><strong>Engineer, volunteer firefighter, beginner pianist,</strong> pragmatic optimist. Writing about technology, society, and the good life — one book at a time.</p>
      </div>
      <div class="hero-portrait">
        <img src="/images/profile.jpg" alt="Stefan Coburn" width="320" height="400" loading="eager" onerror="this.style.display='none';this.parentElement.classList.add('placeholder')" />
      </div>
    </div>

    <div class="hero-stats">
      <div class="stat"><div class="n">{totalBooks}</div><div class="l">Books <em>read</em></div></div>
      <div class="stat"><div class="n">{totalNotes}</div><div class="l">Book <em>notes</em></div></div>
      <div class="stat"><div class="n">14</div><div class="l"><em>Quotes</em> kept</div></div>
      <div class="stat"><div class="n">{essays.length}</div><div class="l"><em>Essays</em> written</div></div>
    </div>

    {currentlyReading.length > 0 && (
      <div style="display:grid;grid-template-columns:140px 1fr;gap:28px;align-items:start;padding:20px 0 32px;border-bottom:1px solid var(--rule);margin-bottom:48px">
        <div style="font-family:var(--mono);font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);padding-top:8px">Currently<br>reading</div>
        <div style="display:flex;gap:32px;flex-wrap:wrap">
          {currentlyReading.map(b => (
            <a href={`/bookshelf#${b.slug}`} style="display:flex;gap:14px;text-decoration:none;color:inherit">
              <div style="width:60px;height:90px;flex-shrink:0;border-radius:2px;overflow:hidden;box-shadow:0 6px 16px -6px rgba(0,0,0,.35);background:var(--bg-panel)">
                {b.hasCover && <img src={`/images/covers/${b.slug}.jpg`} alt={b.title} loading="lazy" style="width:100%;height:100%;object-fit:cover" />}
              </div>
              <div style="padding-top:4px">
                <div style="font-family:var(--display);font-size:15px;font-weight:600;line-height:1.25">{b.title}</div>
                <div style="font-family:var(--ui);font-size:11.5px;color:var(--muted);margin-top:3px">{b.author}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="home-cols">
      <div>
        <div class="col-head">Book Notes <a href="/book-notes">All notes →</a></div>
        {bookNotes.slice(0, 6).map(note => (
          <div class="post-row">
            <a href={`/book-notes/${note.id}`}>{note.data.title}</a>
            <span class="d">{new Date(note.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
            {note.data.description && <span class="desc">{note.data.description}</span>}
          </div>
        ))}
      </div>
      <div>
        <div class="col-head">Essays <a href="/essays">All essays →</a></div>
        {essays.length > 0 ? essays.slice(0, 6).map(essay => (
          <div class="post-row">
            <a href={`/essays/${essay.id}`}>{essay.data.title}</a>
            <span class="d">{new Date(essay.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
            {essay.data.description && <span class="desc">{essay.data.description}</span>}
          </div>
        )) : (
          <p style="color:var(--muted);font-style:italic;font-family:var(--display);font-size:17px;margin-top:8px">Coming soon.</p>
        )}
      </div>
    </div>
  </main>
</BaseLayout>
